{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@gitreqd/core": ["packages/core/src/index.ts"],
      "@gitreqd/core/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages/**/*"]
}

