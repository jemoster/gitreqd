#!/usr/bin/env bash
# GRD-GIT-003: Pre-commit hook – run gitreqd validate for the repository's requirements.
# Install with: ./scripts/install-pre-commit.sh [REPO_DIR]
# Project directory: git repo root unless GITREQD_PROJECT_DIR is set.

set -euo pipefail

GIT_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="${GITREQD_PROJECT_DIR:-${GIT_ROOT}}"
exec gitreqd validate --project-dir "${PROJECT_DIR}"
