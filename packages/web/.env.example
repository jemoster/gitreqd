# Copy to `.env.local` for local Next.js dev. Paths are relative to this file unless noted.

# Required: absolute path to the directory that contains `gitreqd.yaml` (usually the gitreqd-cloud repo root).
# The `gitreqd browser` CLI sets this automatically; when using `next dev` directly, set it yourself or run `npm run dev:web` from the gitreqd-cloud repository root.
GITREQD_PROJECT_ROOT=

# When all four are set, login is required and the Auth0 landing page is shown until the user signs in.
# Omit any of these to run without interactive login (uses the in-repo stub adapter — fine for UI-only work).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_CONNECTION=github
