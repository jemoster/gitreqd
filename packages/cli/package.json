{
  "name": "gitreqd",
  "version": "0.1.0",
  "description": "Requirement management tool — discover, validate, and report requirements from YAML in your repo",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gitreqd": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "requirements",
    "yaml",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@gitreqd/core": "0.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
