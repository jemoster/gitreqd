{
  "name": "gitreqd",
  "private": true,
  "description": "Requirement management tool",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "validate": "node packages/cli/dist/index.js validate",
    "format": "node packages/cli/dist/index.js format",
    "html": "node packages/cli/dist/index.js html",
    "bootstrap": "node packages/cli/dist/index.js bootstrap",
    "test": "jest"
  },
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/vscode",
    "packages/web"
  ],
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "overrides": {
    "dompurify": "3.3.3",
    "brace-expansion": "5.0.5"
  }
}
